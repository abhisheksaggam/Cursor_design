{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["server/**/*.ts", "src/lib/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["node_modules", "src/lib/ui/**/*.ts"]
}
